{
  "consumer": {
    "name": "payment-service"
  },
  "messages": [
    {
      "contents": {
        "amount": 240.0,
        "bookingId": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
        "currency": "USD",
        "customerId": "cust-42",
        "eventId": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
        "eventName": "Symphony Gala",
        "seats": 3
      },
      "description": "a booking confirmed event",
      "generators": {
        "body": {
          "$.bookingId": {
            "type": "Uuid"
          },
          "$.eventId": {
            "type": "Uuid"
          }
        }
      },
      "matchingRules": {
        "body": {
          "$.amount": {
            "combine": "AND",
            "matchers": [
              {
                "match": "decimal"
              }
            ]
          },
          "$.bookingId": {
            "combine": "AND",
            "matchers": [
              {
                "match": "regex",
                "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              }
            ]
          },
          "$.currency": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.customerId": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.eventId": {
            "combine": "AND",
            "matchers": [
              {
                "match": "regex",
                "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
              }
            ]
          },
          "$.eventName": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.seats": {
            "combine": "AND",
            "matchers": [
              {
                "match": "integer"
              }
            ]
          }
        }
      },
      "metaData": {
        "contentType": "application/json"
      }
    }
  ],
  "metadata": {
    "pact-jvm": {
      "version": "4.6.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "booking-service"
  }
}
