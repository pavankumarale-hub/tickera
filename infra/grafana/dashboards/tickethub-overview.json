{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Tickera — Service Overview",
  "uid": "tickera-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM heap used (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka consumer records consumed (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (application) (rate(kafka_consumer_fetch_manager_records_consumed_total[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
